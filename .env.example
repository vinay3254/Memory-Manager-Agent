# Anthropic API key for Claude Haiku compression/summarization
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ChromaDB server URL (run: chroma run --path ./data/chroma)
CHROMA_URL=http://localhost:8000

# ChromaDB collection name
CHROMA_COLLECTION=memory_manager

# SQLite database path
SQLITE_DB_PATH=./data/memories.db

# Embedding model cache directory
TRANSFORMERS_CACHE=./data/model_cache

# Scoring thresholds (optional overrides)
SCORE_STORE_THRESHOLD=0.7
SCORE_COMPRESS_THRESHOLD=0.35

# Retrieval defaults
DEFAULT_RETRIEVE_LIMIT=5
